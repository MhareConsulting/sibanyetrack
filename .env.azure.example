# Copy this to .env on the Azure VM and fill in every value marked <...>

# ── Django core ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=<50-char-random-string>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=<VM_PUBLIC_IP>
# Set to False until you add TLS (Nginx + Let's Encrypt or Azure Front Door)
DJANGO_SECURE_SSL_REDIRECT=False

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=mytrack
POSTGRES_USER=mytrack
POSTGRES_PASSWORD=<strong-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── GPS ingest shared secret ───────────────────────────────────────────────────
# Must match the Bearer token in traccar/traccar.xml
INGEST_API_TOKEN=<strong-random-token>

# ── Traccar / device settings ─────────────────────────────────────────────────
# Shown in the device SMS setup instructions panel in the web UI
TRACCAR_PUBLIC_HOST=<VM_PUBLIC_IP>
TRACCAR_DEFAULT_ORG_SLUG=

# ── Azure Communication Services (email / SMS alerts) ─────────────────────────
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=

# ── myRoutes integration (optional) ───────────────────────────────────────────
MYROUTES_SYNC_URL=
MYROUTES_SYNC_TOKEN=
