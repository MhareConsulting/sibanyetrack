DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production behind nginx: trust X-Forwarded-Proto / Host (fixes CSRF 403 on POST).
# Set to False only if Django is reached directly over HTTPS with no reverse proxy.
# DJANGO_BEHIND_REVERSE_PROXY=True
# DJANGO_USE_X_FORWARDED_HOST=True
# Optional if CSRF still fails: full public origin(s), comma-separated
# DJANGO_CSRF_TRUSTED_ORIGINS=https://track.example.co.za

# Public site URL (links in emails; GitHub Actions scheduled-email workflow)
SITE_URL=http://localhost:8000

# Bearer token for POST /api/cron/email-jobs/ (leave empty to disable the endpoint)
CRON_EMAIL_TRIGGER_TOKEN=

POSTGRES_DB=mytrack
POSTGRES_USER=mytrack
POSTGRES_PASSWORD=mytrack
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Shared secret that myRoutes uses when posting GPS pings
INGEST_API_TOKEN=change-me-shared-secret

# Traccar integration — org slug used when a device doesn't pass one in its attributes
TRACCAR_DEFAULT_ORG_SLUG=your-org-slug

# Public hostname/IP that GPS devices in the field use to reach Traccar.
# Set to your server's public IP or domain name (e.g. track.yourcompany.co.za).
# Shown in the device SMS setup instructions panel.
TRACCAR_PUBLIC_HOST=your-server-ip

# ── Video telematics ──────────────────────────────────────────────────────────

# Minutes either side of clip.occurred_at to search for a matching Alert
VIDEO_ALERT_CORRELATION_WINDOW_MINUTES=5

# Vendor clip-request endpoint (leave blank to disable proactive requests)
VIDEO_CLIP_REQUEST_URL=
VIDEO_CLIP_REQUEST_TOKEN=

# Pre/post event seconds requested from camera vendor
VIDEO_CLIP_PRE_EVENT_SECONDS=30
VIDEO_CLIP_POST_EVENT_SECONDS=30

# Hours without a received clip before a camera channel is flagged as stale
VIDEO_CAMERA_STALE_HOURS=24

# Streamax AD Plus 2.0 alarm push
# Shared secret entered on the camera's Alarm Push screen (Push Password / Token field).
STREAMAX_WEBHOOK_TOKEN=your-streamax-token-here
# Public base URL of this server as seen by the camera — shown in device setup instructions.
# Format: http://<host>:<port>  (no trailing slash)
STREAMAX_PUSH_BASE_URL=http://20.164.200.242:8001
